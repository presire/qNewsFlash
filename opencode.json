{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@tarquinen/opencode-dcp",
    "@franlol/opencode-md-table-formatter",
    "@mohak34/opencode-notifier"
  ],
  "mcp": {
    "pdf-reader": {
      "type": "local",
      "command": ["npx", "@sylphx/pdf-reader-mcp"],
      "enabled": true
    },
    "web-search-prime": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_search_prime/mcp",
      "headers": {
        "Authorization": "GLMのAPIキー"
      }
    },
    "web-reader": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/web_reader/mcp",
      "headers": {
        "Authorization": "GLMのAPIキー"
      }
    },
    "zai-mcp-server": {
      "type": "local",
      "command": ["npx", "-y", "@z_ai/mcp-server"],
      "environment": {
        "Z_AI_API_KEY": "GLMのAPIキー",
        "Z_AI_MODE": "ZAI"
      }
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp", "--api-key", "Context7のAPIキー"],
      "enabled": true
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/path/to/qNewsFlash"],
      "enabled": true
    },
    "grep-app": {
      "type": "local",
      "command": ["npx", "-y", "@luminati-io/grep-app-mcp"],
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": ["npx", "mcp-fetch-server"],
      "enabled": true,
      "environment": {
        "DEFAULT_LIMIT": "50000"
      }
    },
    "websearch": {
      "type": "local",
      "command": ["npx", "-y", "@openwebsearch/websearch-mcp"],
      "enabled": true
    }
  }
}
